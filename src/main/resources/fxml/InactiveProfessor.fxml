<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:controller="uv.lis.professionalpracticesystem.GUIviews.controllers.InactivateProfessorController"
      xmlns:fx="http://javafx.com/fxml" spacing="20" alignment="TOP_CENTER" prefWidth="500">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Inactivar Profesor" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Número de Personal:"/>
        <TextField fx:id="searchFacultyId" prefWidth="150"/>
        <Button text="Buscar" onAction="#handleSearchProfessor"/>
    </HBox>

    <Separator/>

    <GridPane hgap="10" vgap="10" fx:id="professorDataPane" visible="false">
        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="labelName" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        
        <Label text="Correo:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="labelEmail" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Label text="Turno:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="labelShift" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="btnInactivate" text="Inactivar Profesor" onAction="#handleInactivate" disable="true"/>
        <Button text="Cancelar" onAction="#handleCancel"/>
        
    </HBox>
</VBox>